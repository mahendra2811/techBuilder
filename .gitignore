# ─────────────────────────────────────────────────────────────
# techBuilder — root .gitignore (npm workspace: shared · backend · app · proj)
# ─────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.npm/

# Secrets / environment — NEVER commit real env files
.env
.env.*
*.env
!.env.example
!.env.*.example

# Build output
dist/
build/
out/
*.tsbuildinfo
.turbo/

# Next.js (proj/ web scaffold)
.next/
next-env.d.ts

# Expo / React Native (app/)
.expo/
.expo-shared/
web-build/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
# native folders are generated by `expo prebuild` — regenerate, don't commit
app/android/
app/ios/

# Drizzle generated migration metadata (keep hand-written SQL)
drizzle/*.json
drizzle/meta/

# Testing / coverage
coverage/
*.lcov
.nyc_output/

# Logs & debug
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Caches
.cache/
.eslintcache
.parcel-cache/
.metro-health-check*

# Editors / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS cruft
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Misc local / tooling
*.pem
.vercel/
.code-review-graph/
