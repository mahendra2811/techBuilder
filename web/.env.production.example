# techBuilder web — PRODUCTION env template.
#
# Phase 1 (Vercel): set BACKEND_ORIGIN in the Vercel dashboard's Environment Variables UI
# (Production environment), not as a committed file. See docs/deployment/VERCEL_TESTING_GUIDE.md.
#
# Phase 2 (EC2, same box as the backend): copy this to /opt/techbuilder/web/.env, chmod 600,
# owned by the `techbuilder` system user. The Next<->Nest hop is same-box loopback here — no TLS
# needed for it, Caddy terminates the public-facing TLS for both api.example.com and app.example.com.

NODE_ENV=production
BACKEND_ORIGIN=http://localhost:4000
