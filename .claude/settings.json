{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm run typecheck)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run build)",
      "Bash(npm run build:*)",
      "Bash(npm run db:*)",
      "Bash(npm run seed)",
      "Bash(npm test:*)",
      "Bash(npx tsc:*)",
      "Bash(npx drizzle-kit:*)",
      "Bash(npx ctx7:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-frozen-contracts.sh\""
          }
        ]
      }
    ]
  }
}
