{
  "name": "@techbuilder/contracts",
  "version": "1.0.0-frozen.10",
  "private": true,
  "description": "techBuilder Contracts Pack — FROZEN single source of truth (enums, types, OrgConfig, DB schema + RLS, API contract, adapter interfaces). Consumed by backend + frontend engine. Do not edit without a version bump + cross-team sign-off.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "source": "./src/index.ts", "default": "./dist/index.js" },
    "./db/schema": { "types": "./dist/db/schema.d.ts", "source": "./src/db/schema.ts", "default": "./dist/db/schema.js" }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "verify-freeze": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
