# techBuilder backend env
NODE_ENV=development
PORT=4000

# App DB role MUST be non-superuser + NOBYPASSRLS (see shared/src/db/rls.sql).
DATABASE_URL=postgres://techbuilder_app:password@localhost:5432/techbuilder
# Optional privileged URL used only by apply-sql / migrations (table owner). Falls back to DATABASE_URL.
DATABASE_URL_ADMIN=postgres://postgres:password@localhost:5432/techbuilder

JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
ACCESS_TTL_SEC=900
REFRESH_TTL_SEC=2592000

# Comma-separated allowlist of origins allowed to call this API with credentials, e.g.
# "https://app.example.com". Left unset: localhost:3000 in development, block-all in production.
# Only matters if something ever calls this API from a browser directly — today only the Next.js
# server does (server-to-server, Bearer token, see web/src/lib/server/backend.ts).
CORS_ORIGINS=
# Swagger UI at /api/docs — always on outside production; in production only when set to 1
SWAGGER_ENABLED=

# Cloudflare R2 (presigned uploads) — optional until media is wired
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=

# SMTP (emailed Excel exports) — optional; empty = GET /exports/config reports emailEnabled: false
# and the web Reports screen hides the "Send to email" option (download-only).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
