# techBuilder backend — PRODUCTION env template (EC2 + RDS).
# Copy to /opt/techbuilder/backend/.env on the server, chmod 600, owned by the `techbuilder`
# system user (see docs/deployment/PRODUCTION_DEPLOYMENT.md). NEVER commit the filled-in version.

NODE_ENV=production
PORT=4000

# Runtime app role — NOSUPERUSER NOBYPASSRLS, RLS enforced. See docs/deployment/DATABASE_MIGRATION.md.
DATABASE_URL=postgresql://techbuilder_app:<APP_PASSWORD>@<RDS_ENDPOINT>:5432/techbuilder?sslmode=require
# Privileged master role — migrations / apply-sql / seed / backups ONLY. The running app process
# never reads this at runtime (only drizzle.config.ts, apply-sql.ts, and scripts/backup-database.sh do).
DATABASE_URL_ADMIN=postgresql://postgres:<MASTER_PASSWORD>@<RDS_ENDPOINT>:5432/techbuilder?sslmode=require

# Generate fresh secrets for production — do NOT reuse local-dev values:
#   openssl rand -hex 32
JWT_ACCESS_SECRET=<generate-fresh-32-byte-hex>
JWT_REFRESH_SECRET=<generate-fresh-32-byte-hex>
ACCESS_TTL_SEC=900
REFRESH_TTL_SEC=2592000

# The frontend's real production domain(s). Comma-separated if more than one (e.g. during the
# Vercel-then-EC2 transition, both the Vercel domain and app.example.com may need to be listed
# temporarily — though in this architecture the browser never calls this API directly, so this is
# defense-in-depth, not the primary boundary; see docs/deployment/SECURITY_CHECKLIST.md).
CORS_ORIGINS=https://app.example.com

# S3 (media) — fill in once the presigned-upload flow is actually wired to real storage (it isn't
# yet — see the 2026-07-11 audit's File Upload finding). Leave blank until then.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=

# SMTP — authenticated submission, port 587 (STARTTLS) or 465 (implicit TLS). Never port 25.
SMTP_HOST=<your-smtp-provider-host>
SMTP_PORT=587
SMTP_USER=<smtp-username>
SMTP_PASS=<smtp-password>
SMTP_FROM="techBuilder <noreply@example.com>"
