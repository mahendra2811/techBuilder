# techBuilder app env — copy to `app/.env`
#
# Which adapter the app talks to:
#   (unset)  → 'mock'  = seeded offline data, NO backend needed (pure UI testing)
#   rest     → live NestJS backend (real Neon data)
EXPO_PUBLIC_ADAPTER=rest
#
# Backend base URL (origin only — the app appends /api/v1):
#   WiFi (same network):  http://<your-laptop-LAN-IP>:4000   e.g. http://192.168.1.5:4000
#   USB cable + adb reverse tcp:4000 tcp:4000:  http://localhost:4000
EXPO_PUBLIC_API_URL=http://localhost:4000
